# ==========================================
# Core
# ==========================================
NODE_ENV=development
# Optional: if unset, admin login/admin APIs are disabled.
# Generate with: openssl rand -hex 24
ADMIN_KEY=change-me
# Optional but recommended for destructive admin actions (factory reset step-up).
# Keep this different from ADMIN_KEY.
# Generate with: openssl rand -hex 32
ADMIN_RESET_PASSCODE=
# Required (all envs): at least 32 characters.
# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-with-a-random-32-plus-character-secret
# Required in production/preview deploys (recommended to set everywhere).
DATA_MODE=remote

# ==========================================
# Postgres (app uses only DATABASE_URL)
# ==========================================
# Connection string includes user, password, host, port, db. Some hosts may set
# PGHOST, POSTGRES_*, etc.; the app does not read those.
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# Optional pool size override (defaults: dev=1, prod=3; bounded 1..10)
# POSTGRES_POOL_MAX=3
# Local development safety: by default, startup fails if shell env overrides
# critical project env keys like DATABASE_URL or DATA_MODE. Set this only for
# intentional one-off overrides.
# ALLOW_LOCAL_ENV_OVERRIDE=1

# ==========================================
# Public
# ==========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_WHATSAPP_URL=https://chat.whatsapp.com/DcwqLpx0oHl093E3uApKQj
NEXT_PUBLIC_SPOTIFY_PLAYLIST_URL=https://open.spotify.com/playlist/5TFP3Cyoqe75g7CLf3j1iR?si=Jg-WhZlLSDq12cXCg_M9DA&pi=5CTuc9IcSbqjf
NEXT_PUBLIC_APPLE_MUSIC_PLAYLIST_URL=https://music.apple.com/gb/playlist/konzombazouklove/pl.u-2aoqXWaHq8NvKE
NEXT_PUBLIC_YOUTUBE_MUSIC_PLAYLIST_URL=
NEXT_PUBLIC_OOOC_WEBSITE_URL=https://www.outofofficecollective.co.uk/
NEXT_PUBLIC_OOOC_INSTAGRAM_URL=https://www.instagram.com/outofofficecollectivee/
NEXT_PUBLIC_OOOC_TIKTOK_URL=https://www.tiktok.com/@outofofficecollective
NEXT_PUBLIC_OOOC_CONTACT_URL=https://outofofficecollective.co.uk/contact
NEXT_PUBLIC_OOOC_FAQ_URL=https://outofofficecollective.co.uk/faqs
NEXT_PUBLIC_CREATOR_X_URL=https://x.com/milkandh3nny
NEXT_PUBLIC_SUPPORT_COFFEE_URL=https://coff.ee/milkandhenny
NEXT_PUBLIC_TOILET_FINDER_IOS_URL=https://apps.apple.com/app/id311896604
NEXT_PUBLIC_TOILET_FINDER_ANDROID_URL=https://play.google.com/store/apps/details?id=com.bto.toilet&hl=en_GB
NEXT_PUBLIC_FOOD_GUIDE_URL=https://maps.app.goo.gl/YZdYYpsh2ViR2tQi8?g_st=i
# Optional: stable public build id for admin deploy-change detection.
# On Railway, set this to the commit SHA or a unique build timestamp.
NEXT_PUBLIC_DEPLOYMENT_ID=

# Price filters are normalized to EUR while display keeps the entered sheet value.
NEXT_PUBLIC_PRICE_RATE_GBP_TO_EUR=1.154
NEXT_PUBLIC_PRICE_RATE_USD_TO_EUR=0.854

# First-party analytics sampling. Defaults are free-plan conservative:
# high-value event actions and tour progress are always kept; search/filter
# signals are sampled with discovery analytics; low-value nav signals are
# dropped unless opted in.
# Values are decimal rates from 0 to 1.
# NEXT_PUBLIC_ENGAGEMENT_ANALYTICS_SAMPLE_RATE=0.25
# NEXT_PUBLIC_DISCOVERY_ANALYTICS_SAMPLE_RATE=0.25
# NEXT_PUBLIC_LOW_VALUE_ANALYTICS_SAMPLE_RATE=0
# NEXT_PUBLIC_GENRE_PREFERENCE_ANALYTICS_SAMPLE_RATE=0.25

# ==========================================
# Geocoding (map coordinates)
# ==========================================
# Optional: enable Geocoding API in Cloud Console.
# If unset, arrondissement centre fallback is used.
GOOGLE_MAPS_API_KEY=

# ==========================================
# Event OCR (admin screenshot-to-sheet drafts)
# ==========================================
# Optional: enables /admin/content event sheet OCR uploads.
# EVENT_OCR_PROVIDER is intentionally generic so providers can be swapped later.
# Supported today: gemini.
EVENT_OCR_PROVIDER=gemini
# Defaults to gemini-2.5-flash-lite when omitted.
EVENT_OCR_MODEL=gemini-2.5-flash-lite
# Prefer the generic key for provider-agnostic config.
EVENT_OCR_API_KEY=
# Gemini-specific fallback if you already have this name somewhere.
GEMINI_API_KEY=
# Optional request timeout in ms.
# EVENT_OCR_TIMEOUT_MS=25000

# ==========================================
# Cron (optional; for scheduled cleanup and backups)
# ==========================================
# Optional: protects cron routes:
# - /api/cron/cleanup-admin-sessions
# - /api/cron/cleanup-rate-limits
# - /api/cron/backup-event-store
# - /api/cron/cleanup-dismissed-partner-reports
# Scheduled callers should send Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -base64 48
# CRON_SECRET=

# Optional: protects /api/revalidate/deploy post-deploy hook.
# Generate with: openssl rand -base64 48
# DEPLOY_REVALIDATE_SECRET=

# ==========================================
# Partner page payment links (Stripe)
# ==========================================
# Optional for local/dev. If missing, partner page CTAs fallback to contact email.
NEXT_PUBLIC_STRIPE_LINK_SPOTLIGHT_STANDARD=
NEXT_PUBLIC_STRIPE_LINK_SPOTLIGHT_TAKEOVER=
NEXT_PUBLIC_STRIPE_LINK_PROMOTED=
NEXT_PUBLIC_STRIPE_LINK_ADDON_WHATSAPP=
NEXT_PUBLIC_STRIPE_LINK_ADDON_NEWSLETTER=

# ==========================================
# Stripe webhook (server-only)
# ==========================================
# Used by /api/webhooks/stripe to verify signed Stripe webhook events.
STRIPE_WEBHOOK_SECRET=
# Optional mapping of Stripe Payment Link IDs to package keys for admin queue labels.
STRIPE_PAYMENT_LINK_ID_SPOTLIGHT_STANDARD=
STRIPE_PAYMENT_LINK_ID_SPOTLIGHT_TAKEOVER=
STRIPE_PAYMENT_LINK_ID_PROMOTED=
STRIPE_PAYMENT_LINK_ID_ADDON_WHATSAPP=
STRIPE_PAYMENT_LINK_ID_ADDON_NEWSLETTER=

# ==========================================
# Ticket Exchange
# ==========================================
# Email hooks are built but disabled until a transactional provider is configured.
TICKET_EXCHANGE_EMAIL_ENABLED=false
TICKET_EXCHANGE_FROM_EMAIL=tickets@fete.outofofficecollective.co.uk
TICKET_EXCHANGE_REPLY_TO=tickets@outofofficecollective.co.uk
# Protects bot-only endpoints. Generate with: openssl rand -base64 48
TICKET_EXCHANGE_BOT_SECRET=
