{
  "name": "oooc-fete-finder",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev --turbopack -H 127.0.0.1 -p ${PORT:-3000}",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "deadcode": "knip",
    "deadcode:exports": "ts-prune -i \"(^|/)\\\\.next/\"",
    "deadcode:all": "pnpm deadcode && pnpm deadcode:exports",
    "fix": "biome check --write",
    "format": "biome format . --write",
    "bootstrap:postgres-store": "node scripts/bootstrap-postgres-store.mjs",
    "bootstrap:featured-schedule": "node scripts/seed-featured-schedule-from-legacy.mjs",
    "backfill:user-identity": "node scripts/backfill-user-identity.mjs",
    "db:pull-events-csv": "node scripts/pull-event-store-csv.mjs",
    "check:user-id-drift": "node scripts/check-user-identity-drift.mjs",
    "health:check": "node scripts/health-check.mjs",
    "check:public-routes": "node scripts/check-public-routes.mjs",
    "generate:og": "node scripts/generate-static-og-images.mjs",
    "db:cli": "node scripts/db-cli.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@types/papaparse": "^5.5.2",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.564.0",
    "maplibre-gl": "^5.18.0",
    "modern-screenshot": "^4.6.8",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.1",
    "web-haptics": "^0.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/geojson": "^7946.0.16",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "knip": "^5.84.1",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "ts-prune": "^0.10.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10",
      "protocol-buffers-schema": "3.6.1"
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  }
}
